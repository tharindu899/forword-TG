# Local development only. On Render, set these in Environment — never commit secrets.
BOT_TOKEN=123456789:replace_with_your_bot_token

# Recommended: your numeric Telegram user ID. Use /id in the bot PM to find it.
# Set 0 only if you want to claim the bot once via /claim.
OWNER_ID=0

# Optional deployment secrets requested for your Telegram app profile.
# This Bot API copier does NOT use them for copying or user login.
# Keep both private and do not send them through bot commands.
API_ID=
API_HASH=

# Local data folder. Render uses /var/data from render.yaml.
DATA_DIR=./data

# Resume a job interrupted by a Render restart. A manual /pause stays paused.
AUTO_RESUME=true
POLL_TIMEOUT_SECONDS=25
HTTP_TIMEOUT_SECONDS=45
NETWORK_RETRY_SECONDS=8
LOG_LEVEL=INFO
