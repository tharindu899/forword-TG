# Required — keep real values private. Never commit a filled .env file.
BOT_TOKEN=<YOUR_BOT_TOKEN>
API_ID=<YOUR_TELEGRAM_API_ID>
API_HASH=<YOUR_TELEGRAM_API_HASH>

# Optional. Used only to migrate a previous one-user database profile.
# It does NOT restrict access when ALLOW_ALL_USERS=true.
OWNER_ID=0

# Multi-user access
ALLOW_ALL_USERS=true
MAX_ACTIVE_JOBS=3

# Runtime
SESSION_NAME=channel_copier_mtproto_bot
DATA_DIR=./data
AUTO_RESUME=false
PYROGRAM_IPV6=false
LOG_LEVEL=INFO

# Optional — force users to join one public channel before using the bot.
# Add the bot as an admin in that channel, then set only its @username.
# Leave empty to disable force subscription.
FORCE_SUB_CHANNEL=@TharinduHub
